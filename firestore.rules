rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Catalog & site settings (categories, brands, zones, promos, blog, general
    // config) — the storefront needs to read all of this publicly, but only
    // the authenticated admin can change it.
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Products — public read so the storefront can list/show items.
    // Only the admin can create/edit/delete products or change stock/prices.
    match /products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders — a shopper must be able to CREATE a new order from the
    // storefront with no login. But nobody public should be able to read
    // other people's orders, or update/delete any order (that would let a
    // stranger mark a sale as confirmed, or erase pending orders).
    match /orders/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Customers — contains names, cédulas, emails, phone numbers. Never
    // publicly readable or writable. Only the admin panel touches this.
    match /customers/{id} {
      allow read, write: if request.auth != null;
    }

    // Anything else not explicitly listed above: deny by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
